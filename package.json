{
  "name": "wabox",
  "version": "0.1.8",
  "description": "A bridge between WhatsApp and the filesystem — incoming messages/files land in an inbox folder, an outbox folder is watched and sent back. Built on Baileys.",
  "type": "module",
  "main": "index.js",
  "bin": {
    "wabox": "bin/cli.js"
  },
  "author": "Rodrigo Couto <r@rodg.co>",
  "license": "MIT",
  "homepage": "https://github.com/rodgco/wabox#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rodgco/wabox.git"
  },
  "bugs": {
    "url": "https://github.com/rodgco/wabox/issues"
  },
  "keywords": [
    "whatsapp",
    "baileys",
    "bridge",
    "gateway",
    "filesystem",
    "inbox",
    "outbox",
    "cli"
  ],
  "files": [
    "bin/",
    "src/",
    "config.js",
    "index.js",
    "README.md",
    "CHANGELOG.md",
    "INTEGRATION.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node bin/cli.js run",
    "config": "node bin/cli.js config",
    "dev": "node --watch bin/cli.js run",
    "build:skill": "node scripts/build-skill.mjs",
    "check:skill": "node scripts/build-skill.mjs --check",
    "docs:dev": "vitepress dev website",
    "docs:build": "vitepress build website",
    "docs:preview": "vitepress preview website",
    "release": "node scripts/release.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^6.7.18",
    "chokidar": "^4.0.3",
    "pino": "^9.6.0",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "vitepress": "^1.6.4"
  },
  "allowScripts": {
    "@whiskeysockets/baileys@6.7.23": true,
    "protobufjs@7.6.2": true,
    "sharp@0.34.5": true,
    "esbuild@0.21.5": true
  }
}
